# ============================================
# FARMADOM — Backend Configuration
# ============================================

NODE_ENV=development
PORT=8000

# ============================================
# MYSQL LOCAL
# Certifique-se de que o MySQL está rodando localmente
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=farmadom

# ============================================
# SECURITY
# ============================================
JWT_SECRET=sua-chave-secreta-muito-forte-aqui
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# EMAIL (SMTP) - Opcional
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@farmadom.ao

# ============================================
# UPLOAD
# ============================================
UPLOAD_DIR=./uploads

# ============================================
# APP URL
# ============================================
APP_URL=http://localhost:8000


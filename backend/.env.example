# ============================================
# FARMADOM — Backend Configuration
# ============================================

NODE_ENV=development
PORT=8000

# ============================================
# MYSQL REMOTO - Servidor de Produção
# Host: 192.185.131.80
# Porta: 3306
# ============================================
MYSQL_HOST=192.185.131.80
MYSQL_PORT=3306
MYSQL_USER=ononam25_domingos
MYSQL_PASSWORD=coloque-sua-senha-aqui
MYSQL_DATABASE=ononam25_fdom

# ============================================
# SECURITY
# ============================================
JWT_SECRET=sua-chave-secreta-muito-forte-aqui
JWT_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# EMAIL (SMTP) - Opcional
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@farmadom.ao

# ============================================
# UPLOAD
# ============================================
UPLOAD_DIR=./uploads

# ============================================
# APP URL
# ============================================
APP_URL=http://localhost:8000

